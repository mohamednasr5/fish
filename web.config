<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- ═══════════════════════════════════════════════════════════
         رؤوس HTTP للتخزين المؤقت
         ═════════════════════════════════════════════════════════ -->
    <staticContent>
      <!-- ملفات JSON -->
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".webmanifest" mimeType="application/manifest+json" />
      
      <!-- خطوط الويب -->
      <mimeMap fileExtension=".woff" mimeType="application/font-woff" />
      <mimeMap fileExtension=".woff2" mimeType="application/font-woff2" />
      <mimeMap fileExtension=".ttf" mimeType="application/octet-stream" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <!-- منع التخزين المؤقت للملفات الديناميكية -->
        <add name="Cache-Control" value="max-age=300, must-revalidate" />
        <add name="Pragma" value="public" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="SAMEORIGIN" />
      </customHeaders>
    </httpProtocol>

    <!-- ═══════════════════════════════════════════════════════════
         قواعد إعادة الكتابة للـ SPA
         ═════════════════════════════════════════════════════════ -->
    <rewrite>
      <rules>
        <!-- تخزين مؤقت طويل للأصول الثابتة -->
        <rule name="StaticContentCaching" stopProcessing="true">
          <match url="^(.+)\.(jpg|jpeg|png|gif|ico|css|js|svg|woff|woff2|ttf|eot)$" />
          <action type="Rewrite" url="/{R:0}" />
          <add header="Cache-Control" value="max-age=31536000, public" />
        </rule>

        <!-- Service Worker - لا تخزين مؤقت -->
        <rule name="ServiceWorkerNoCaching">
          <match url="^sw\.js$" />
          <add header="Cache-Control" value="max-age=0, no-cache, no-store, must-revalidate" />
          <add header="Pragma" value="no-cache" />
          <add header="Expires" value="0" />
        </rule>

        <!-- Manifest - تخزين مؤقت قصير -->
        <rule name="ManifestCaching">
          <match url="^manifest\.json$|\.webmanifest$" />
          <add header="Cache-Control" value="max-age=3600, must-revalidate" />
          <add header="Content-Type" value="application/manifest+json; charset=UTF-8" />
        </rule>

        <!-- إعادة توجيه لـ SPA -->
        <rule name="AngularJS_Fallback" stopProcessing="true">
          <match url="^(?!(\.|api|assets|fonts|images)).*$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- ═══════════════════════════════════════════════════════════
         ضغط Gzip
         ═════════════════════════════════════════════════════════ -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- ═══════════════════════════════════════════════════════════
         معالجات الملفات
         ═════════════════════════════════════════════════════════ -->
    <handlers>
      <add name="StaticFile" path="*" verb="*" modules="StaticFileModule" 
           resourceType="Either" requireAccess="Read" />
    </handlers>

    <!-- ═══════════════════════════════════════════════════════════
         معايير الأمان
         ═════════════════════════════════════════════════════════ -->
    <security>
      <authorization>
        <add accessType="Allow" users="*" />
      </authorization>
    </security>
  </system.webServer>

  <!-- ═══════════════════════════════════════════════════════════
       إعدادات التطبيق
       ═════════════════════════════════════════════════════════ -->
  <appSettings>
    <add key="aspnet:UseTaskFriendlyException" value="true" />
  </appSettings>
</configuration>
